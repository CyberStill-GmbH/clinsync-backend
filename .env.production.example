# ──────────────────────────────────────────────────────────────────────
# ClinSync Backend - Production Environment Variables Template (Railway)
# ──────────────────────────────────────────────────────────────────────
# Copy these key-value pairs and paste them into the "Variables" tab
# of your Railway project dashboard.

# ── Port & Server Environment ──────────────────────────────────────────
# Railway will automatically inject the dynamic PORT variable.
# Keep this defined to allow fallback.
PORT=3000
NODE_ENV=production

# ── Database Configuration ─────────────────────────────────────────────
# Paste your Railway PostgreSQL Connection String here.
# Example: postgresql://postgres:password@junction.railway.internal:5432/railway
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# ── Security & Authentication ──────────────────────────────────────────
# Generate a cryptographically secure 256-bit string for JWT signing.
# Example command to generate one: openssl rand -base64 32
JWT_SECRET="generate-a-strong-jwt-secret-string-here"

# ── CORS Policy Whitelist ──────────────────────────────────────────────
# The exact URL where your frontend is deployed (e.g., Vercel, Netlify, Github Pages).
# Do NOT put a trailing slash.
# Example: https://clinsync.vercel.app
FRONTEND_URL="https://your-frontend-deployment-domain.com"
